<Window
    x:Class="LiveCaptionsTranslator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LiveCaptionsTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{DynamicResource MainWindowTitle}"
    Width="750"
    Height="170"
    MinWidth="750"
    MinHeight="170"
    Background="Transparent"
    LocationChanged="MainWindow_LocationChanged"
    ResizeMode="CanResizeWithGrip"
    SizeChanged="MainWindow_SizeChanged"
    Topmost="True"
    AllowsTransparency="True"
    WindowStartupLocation="Manual"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid>
        <Border
            x:Name="WindowBackgroundBorder"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            ClipToBounds="True" />
        <Border
            Background="Transparent"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="Transparent"
            ClipToBounds="True">
            <Grid x:Name="MainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar
                Grid.Row="0"
                Height="27"
                ShowMaximize="False">
                <ui:TitleBar.Header>
                    <ui:TextBlock Padding="15,0,0,0" VerticalAlignment="Center" Text="{DynamicResource MainWindowTitle}" />
                </ui:TitleBar.Header>
                <ui:TitleBar.TrailingContent>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <ui:Button
                            x:Name="ClearButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="ClearButton_Click"
                            Icon="{ui:SymbolIcon Delete16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipClearTranslations}"
                            Visibility="Collapsed" />
                        <ui:Button
                            x:Name="AutoScrollButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="AutoScrollButton_Click"
                            Icon="{ui:SymbolIcon ArrowDown16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipAutoScroll}"
                            Visibility="Collapsed" />
                        <ui:Button
                            x:Name="ShowOriginalButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="ShowOriginalButton_Click"
                            Icon="{ui:SymbolIcon Eye16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipShowOriginal}"
                            Visibility="Collapsed" />
                        <ui:Button
                            x:Name="CaptionLogButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="CaptionLogButton_Click"
                            Icon="{ui:SymbolIcon History16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipLogCards}"
                            Visibility="Collapsed" />
                        <ui:Button
                            x:Name="LogOnlyButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="LogOnlyButton_Click"
                            Icon="{ui:SymbolIcon Pause16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipPauseTranslation}" />
                        <ui:Button
                            x:Name="LiveCaptionsToggleButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="LiveCaptionsToggleButton_Click"
                            Icon="{ui:SymbolIcon Live24,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipLiveCaptions}" />
                        <ui:Button
                            x:Name="OverlayModeButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="OverlayModeButton_Click"
                            Icon="{ui:SymbolIcon ClosedCaptionOff24,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipOverlayWindow}" />
                        <ui:Button
                            x:Name="TopmostButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="TopmostButton_Click"
                            Icon="{ui:SymbolIcon Pin16,
                                                 Filled=True}"
                            ToolTip="{DynamicResource ToolTipAlwaysOnTop}" />
                    </StackPanel>
                </ui:TitleBar.TrailingContent>
            </ui:TitleBar>

            <ui:NavigationView
                x:Name="RootNavigation"
                Grid.Row="1"
                HeaderVisibility="Collapsed"
                IsBackButtonVisible="Collapsed"
                IsPaneOpen="False"
                IsPaneToggleVisible="False"
                PaneDisplayMode="LeftMinimal">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem
                        Margin="0,6,0,3"
                        Content="{DynamicResource NavCaption}"
                        FontFamily="Bahnschrift"
                        Icon="{ui:SymbolIcon Home24}"
                        NavigationCacheMode="Enabled"
                        TargetPageType="{x:Type local:CaptionPage}" />
                    <ui:NavigationViewItem
                        x:Name="NavSettingItem"
                        Margin="0,3,0,0"
                        Content="{DynamicResource NavSetting}"
                        FontFamily="Bahnschrift"
                        Icon="{ui:SymbolIcon Settings24}"
                        Click="NavSettingItem_Click" />
                    <ui:NavigationViewItem
                        Margin="0,3,0,0"
                        Content="{DynamicResource NavHistory}"
                        FontFamily="Bahnschrift"
                        Icon="{ui:SymbolIcon History24}"
                        NavigationCacheMode="Disabled"
                        TargetPageType="{x:Type local:HistoryPage}" />
                    <ui:NavigationViewItem
                        Margin="0,3,0,0"
                        Content="{DynamicResource NavInfo}"
                        FontFamily="Bahnschrift"
                        Icon="{ui:SymbolIcon Info24}"
                        NavigationCacheMode="Required"
                        TargetPageType="{x:Type local:InfoPage}" />
                </ui:NavigationView.MenuItems>

                <ui:NavigationView.ContentOverlay>
                    <Grid>
                        <ui:SnackbarPresenter
                            x:Name="snackbarHost"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom" />
                    </Grid>
                </ui:NavigationView.ContentOverlay>
            </ui:NavigationView>
        </Grid>
        </Border>
        <ContentPresenter
            x:Name="DialogHostContainer"
            MinHeight="167"
            Visibility="Collapsed" />
    </Grid>
</Window>
