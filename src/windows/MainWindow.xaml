<Window
    x:Class="LiveCaptionsTranslator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LiveCaptionsTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{DynamicResource MainWindowTitle}"
    Width="750"
    Height="170"
    MinWidth="300"
    MinHeight="60"
    Background="Transparent"
    LocationChanged="MainWindow_LocationChanged"
    ResizeMode="CanResizeWithGrip"
    SizeChanged="MainWindow_SizeChanged"
    Topmost="True"
    AllowsTransparency="True"
    WindowStartupLocation="Manual"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid>
        <Border
            x:Name="WindowBackgroundBorder"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            ClipToBounds="True" />
        <Border
            Background="Transparent"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="Transparent"
            ClipToBounds="True">
            <Grid x:Name="MainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar
                Grid.Row="0"
                Height="27"
                ShowMaximize="False">

                <ui:TitleBar.TrailingContent>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <ui:Button
                            x:Name="ClearButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="ClearButton_Click"
                            Icon="{ui:SymbolIcon Delete16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipClearTranslations}"
                            Visibility="Collapsed" />
                        <ui:Button
                            x:Name="AutoScrollButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="AutoScrollButton_Click"
                            Icon="{ui:SymbolIcon ArrowDown16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipAutoScroll}"
                            Visibility="Collapsed" />
                        <ui:Button
                            x:Name="ShowOriginalButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="ShowOriginalButton_Click"
                            Icon="{ui:SymbolIcon Eye16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipShowOriginal}"
                            Visibility="Collapsed" />
                        <ui:Button
                            x:Name="TogglePreviewButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="TogglePreviewButton_Click"
                            Icon="{ui:SymbolIcon EyeOff16, Filled=False}"
                            ToolTip="未確定プレビューの表示/非表示" />
                        <ui:Button
                            x:Name="LogOnlyButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="LogOnlyButton_Click"
                            Icon="{ui:SymbolIcon Pause16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipPauseTranslation}" />
                        <ui:Button
                            x:Name="LiveCaptionsToggleButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="LiveCaptionsToggleButton_Click"
                            Icon="{ui:SymbolIcon Live24,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipLiveCaptions}" />

                        <ui:Button
                            x:Name="TopmostButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="TopmostButton_Click"
                            Icon="{ui:SymbolIcon Pin16,
                                                 Filled=True}"
                            ToolTip="{DynamicResource ToolTipAlwaysOnTop}" />
                        <ui:Button
                            x:Name="BatchTranslateButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="BatchTranslateButton_Click"
                            Icon="{ui:SymbolIcon Translate16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource ToolTipBatchTranslate}" />
                        <ui:Button
                            x:Name="SettingButton"
                            Margin="0,0,5,0"
                            Appearance="Transparent"
                            Click="SettingButton_Click"
                            Icon="{ui:SymbolIcon Settings16,
                                                 Filled=False}"
                            ToolTip="{DynamicResource NavSetting}" />
                    </StackPanel>
                </ui:TitleBar.TrailingContent>
            </ui:TitleBar>

            <Frame
                x:Name="RootNavigation"
                Grid.Row="1"
                NavigationUIVisibility="Hidden" />
            <ui:SnackbarPresenter
                x:Name="snackbarHost"
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom" />
        </Grid>
        </Border>
        <Border
            x:Name="LoadingOverlay"
            Background="#66000000"
            CornerRadius="8"
            Visibility="Collapsed">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="4" Margin="0,0,0,10" />
                    <ui:TextBlock Text="一括翻訳中..." Foreground="White" FontSize="13" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
        <ContentPresenter
            x:Name="DialogHostContainer"
            Visibility="Collapsed" />
    </Grid>
</Window>
