<ui:FluentWindow
    x:Class="LiveCaptionsTranslator.AppSettingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LiveCaptionsTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{DynamicResource AppSettingTitle}"
    Width="800"
    Height="600"
    MinWidth="750"
    MinHeight="500"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    Topmost="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Height="27"
            ShowMaximize="False">
            <ui:TitleBar.Header>
                <ui:TextBlock Padding="15,0,0,0" VerticalAlignment="Center" Text="{DynamicResource AppSettingTitle}" />
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左側ナビゲーションサイドバー -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Width="160">
                        <ui:Button
                            x:Name="GeneralNavButton"
                            Margin="10,10,10,0"
                            Padding="10"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            Click="NavigationButton_Click"
                            Tag="General">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Margin="0,0,10,0" Symbol="Settings24" />
                                <ui:TextBlock VerticalAlignment="Center" Text="全般" />
                            </StackPanel>
                        </ui:Button>

                        <ui:Button
                            x:Name="TranslationNavButton"
                            Margin="10,5,10,0"
                            Padding="10"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            Click="NavigationButton_Click"
                            Tag="Translation">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Margin="0,0,10,0" Symbol="LocalLanguage24" />
                                <ui:TextBlock VerticalAlignment="Center" Text="翻訳" />
                            </StackPanel>
                        </ui:Button>

                        <ui:Button
                            x:Name="DisplayNavButton"
                            Margin="10,5,10,0"
                            Padding="10"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            Click="NavigationButton_Click"
                            Tag="Display">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Margin="0,0,10,0" Symbol="TextFont24" />
                                <ui:TextBlock VerticalAlignment="Center" Text="表示・字幕" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 右側コンテンツエリア -->
            <Border
                Grid.Column="1"
                Margin="4"
                Background="{ui:ThemeResource SystemFillColorNeutralBackgroundBrush}"
                CornerRadius="8">
                <ScrollViewer x:Name="ContentScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ContentPanel" Margin="25">
                        
                        <!-- セクション: 全般 -->
                        <StackPanel x:Name="GeneralSection" Margin="0,0,0,30">
                            <ui:TextBlock
                                Margin="5,0,0,15"
                                FontSize="20"
                                FontWeight="Bold"
                                Text="全般設定" />

                            <!-- カード: LiveCaptions コントローラー -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelLiveCaptions}" />
                                            <Button
                                                x:Name="LiveCaptionsInfo"
                                                Width="16"
                                                Height="16"
                                                Margin="5,0,0,0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Focusable="False">
                                                <Button.ToolTip>
                                                    <ToolTip MaxWidth="300">
                                                        <TextBlock TextWrapping="Wrap" Text="{DynamicResource LiveCaptionsInfo}" />
                                                    </ToolTip>
                                                </Button.ToolTip>
                                                <ui:SymbolIcon Symbol="Info16" />
                                            </Button>
                                        </StackPanel>
                                        <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,20,0" Text="Windows Live Captions の表示・非表示を制御します。" />
                                    </StackPanel>
                                    <ui:Button
                                        Grid.Column="1"
                                        x:Name="LiveCaptionsButton"
                                        Width="100"
                                        Height="32"
                                        Click="LiveCaptionsButton_Click"
                                        Appearance="Primary">
                                        <TextBlock x:Name="ButtonText" Text="{DynamicResource ButtonShow}" />
                                    </ui:Button>
                                </Grid>
                            </ui:Card>

                            <!-- カード: API 呼び出し間隔 -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelAPIInterval}" />
                                            <Button
                                                x:Name="FrequencyInfo"
                                                Width="16"
                                                Height="16"
                                                Margin="5,0,0,0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Focusable="False">
                                                <Button.ToolTip>
                                                    <ToolTip MaxWidth="300">
                                                        <TextBlock TextWrapping="Wrap" Text="{DynamicResource APIIntervalInfo}" />
                                                    </ToolTip>
                                                </Button.ToolTip>
                                                <ui:SymbolIcon Symbol="Info16" />
                                            </Button>
                                        </StackPanel>
                                        <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,20,0" Text="翻訳APIの呼び出し頻度（スライダーが小さいほど頻繁に翻訳）" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Slider
                                            Width="150"
                                            VerticalAlignment="Center"
                                            AutoToolTipPlacement="TopLeft"
                                            AutoToolTipPrecision="0"
                                            Maximum="10"
                                            Minimum="1"
                                            Value="{Binding MaxSyncInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ui:TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Width="20" HorizontalAlignment="Right" Text="{Binding MaxSyncInterval}" />
                                    </StackPanel>
                                </Grid>
                            </ui:Card>

                            <!-- カード: レイテンシ表示 -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelShowLatency}" />
                                        <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="翻訳の所要時間（レイテンシ）を字幕画面に表示します。" />
                                    </StackPanel>
                                    <ui:ToggleSwitch
                                        Grid.Column="1"
                                        IsChecked="{Binding MainWindow.LatencyShow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        OffContent="{DynamicResource Off}"
                                        OnContent="{DynamicResource On}" />
                                </Grid>
                            </ui:Card>
                        </StackPanel>

                        <!-- セクション: 翻訳 -->
                        <StackPanel x:Name="TranslationSection" Margin="0,0,0,30">
                            <ui:TextBlock
                                Margin="5,0,0,15"
                                FontSize="20"
                                FontWeight="Bold"
                                Text="翻訳設定" />

                            <!-- カード: 翻訳 API と API 設定ボタン -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelTranslateAPI}" />
                                                <Button
                                                    x:Name="TranslateAPIInfo"
                                                    Width="16"
                                                    Height="16"
                                                    Margin="5,0,0,0"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Focusable="False">
                                                    <Button.ToolTip>
                                                        <ToolTip MaxWidth="300">
                                                            <TextBlock TextWrapping="Wrap" Text="{DynamicResource TranslateAPIInfo}" />
                                                        </ToolTip>
                                                    </Button.ToolTip>
                                                    <ui:SymbolIcon Symbol="Info16" />
                                                </Button>
                                            </StackPanel>
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,20,0" Text="使用する翻訳APIエンジンを設定します。" />
                                        </StackPanel>
                                        <ComboBox
                                            Grid.Column="1"
                                            x:Name="TranslateAPIBox"
                                            Width="160"
                                            Height="32"
                                            VerticalAlignment="Center"
                                            SelectedItem="{Binding ApiName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="TranslateAPIBox_SelectionChanged" />
                                    </Grid>
                                    <Separator Grid.Row="1" Margin="0,5,0,10" />
                                    <Grid Grid.Row="1" Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="各APIの認証キーや詳細パラメーターを設定します。" />
                                        <ui:Button
                                            Grid.Column="1"
                                            x:Name="APISettingButton"
                                            Width="160"
                                            Height="32"
                                            Click="APISettingButton_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Margin="0,0,5,0" Symbol="Settings16" />
                                                <TextBlock Text="API設定を開く" />
                                            </StackPanel>
                                        </ui:Button>
                                    </Grid>
                                </Grid>
                            </ui:Card>

                            <!-- カード: 翻訳先言語 -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelTargetLanguage}" />
                                            <Button
                                                x:Name="TargetLangInfo"
                                                Width="16"
                                                Height="16"
                                                Margin="5,0,0,0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Focusable="False">
                                                <Button.ToolTip>
                                                    <ToolTip MaxWidth="300">
                                                        <TextBlock TextWrapping="Wrap" Text="{DynamicResource TargetLanguageInfo}" />
                                                    </ToolTip>
                                                </Button.ToolTip>
                                                <ui:SymbolIcon Symbol="Info16" />
                                            </Button>
                                        </StackPanel>
                                        <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,20,0" Text="翻訳先のターゲット言語を指定します。" />
                                    </StackPanel>
                                    <ComboBox
                                        Grid.Column="1"
                                        x:Name="TargetLangBox"
                                        Width="160"
                                        Height="32"
                                        IsEditable="True"
                                        LostFocus="TargetLangBox_LostFocus"
                                        SelectionChanged="TargetLangBox_SelectionChanged" />
                                </Grid>
                            </ui:Card>

                            <!-- カード: 自動翻訳 -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelAutoTranslate}" />
                                            <Button
                                                x:Name="AutoTranslateInfo"
                                                Width="16"
                                                Height="16"
                                                Margin="5,0,0,0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Focusable="False">
                                                <Button.ToolTip>
                                                    <ToolTip MaxWidth="300">
                                                        <TextBlock TextWrapping="Wrap" Text="{DynamicResource AutoTranslateInfo}" />
                                                    </ToolTip>
                                                </Button.ToolTip>
                                                <ui:SymbolIcon Symbol="Info16" />
                                            </Button>
                                        </StackPanel>
                                        <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,20,0" Text="字幕の生成に合わせて自動的に翻訳を実行します。" />
                                    </StackPanel>
                                    <ui:ToggleSwitch
                                        Grid.Column="1"
                                        x:Name="AutoTranslateSwitch"
                                        IsChecked="{Binding AutoTranslate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        OffContent="{DynamicResource Off}"
                                        OnContent="{DynamicResource On}" />
                                </Grid>
                            </ui:Card>

                            <!-- カード: 文脈認識 ＆ コンテキスト数 ＆ 表示文数 -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelContextAware}" />
                                                <Button
                                                    x:Name="ContextAwareInfo"
                                                    Width="16"
                                                    Height="16"
                                                    Margin="5,0,0,0"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Focusable="False">
                                                    <Button.ToolTip>
                                                        <ToolTip MaxWidth="300">
                                                            <TextBlock TextWrapping="Wrap" Text="{DynamicResource ContextAwareInfo}" />
                                                        </ToolTip>
                                                    </Button.ToolTip>
                                                    <ui:SymbolIcon Symbol="Info16" />
                                                </Button>
                                            </StackPanel>
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,20,0" Text="前後の文脈を考慮した翻訳を行います（精度が向上します）。" />
                                        </StackPanel>
                                        <ui:ToggleSwitch
                                            Grid.Column="1"
                                            IsChecked="{Binding ContextAware, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            OffContent="{DynamicResource Off}"
                                            OnContent="{DynamicResource On}" />
                                    </Grid>
                                    <Separator Margin="0,5,0,10" />
                                    <Grid Margin="0,5,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelContexts}" />
                                                <Button
                                                    x:Name="CaptionLogMaxInfo"
                                                    Width="16"
                                                    Height="16"
                                                    Margin="5,0,0,0"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Focusable="False">
                                                    <Button.ToolTip>
                                                        <ToolTip MaxWidth="350">
                                                            <TextBlock TextWrapping="Wrap" Text="{DynamicResource ContextsInfo}" />
                                                        </ToolTip>
                                                    </Button.ToolTip>
                                                    <ui:SymbolIcon Symbol="Info16" />
                                                </Button>
                                            </StackPanel>
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,20,0" Text="文脈認識に含める履歴の数（オーバーレイ表示文数の上限）" />
                                        </StackPanel>
                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="120"
                                            Height="32"
                                            ClearButtonEnabled="False"
                                            AcceptsExpression="False"
                                            SpinButtonPlacementMode="Inline"
                                            Maximum="10"
                                            Minimum="1"
                                            Value="{Binding NumContexts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            ValueChanged="Contexts_ValueChanged" />
                                    </Grid>
                                    <Separator Margin="0,5,0,10" />
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelDisplaySentences}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="メイン画面に同時に表示する文の数（ログ表示時）" />
                                        </StackPanel>
                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="120"
                                            Height="32"
                                            ClearButtonEnabled="False"
                                            AcceptsExpression="False"
                                            SpinButtonPlacementMode="Inline"
                                            Maximum="6"
                                            Minimum="0"
                                            Value="{Binding DisplaySentences, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            ValueChanged="DisplaySentences_ValueChanged" />
                                    </Grid>
                                </StackPanel>
                            </ui:Card>

                            <!-- カード: テキスト蓄積翻訳 -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelAccumulateTrans}" />
                                                <Button
                                                    x:Name="AccumulateEnabledInfo"
                                                    Width="16"
                                                    Height="16"
                                                    Margin="5,0,0,0"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Focusable="False">
                                                    <Button.ToolTip>
                                                        <ToolTip MaxWidth="300">
                                                            <TextBlock TextWrapping="Wrap" Text="{DynamicResource AccumulateTransInfo}" />
                                                        </ToolTip>
                                                    </Button.ToolTip>
                                                    <ui:SymbolIcon Symbol="Info16" />
                                                </Button>
                                            </StackPanel>
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,20,0" Text="文字が一定量蓄積されるまで待機してから翻訳します（API節約と翻訳品質向上）。" />
                                        </StackPanel>
                                        <ui:ToggleSwitch
                                            Grid.Column="1"
                                            x:Name="AccumulateEnabledSwitch"
                                            IsChecked="{Binding AccumulateEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding AutoTranslate, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                            OffContent="{DynamicResource Off}"
                                            OnContent="{DynamicResource On}" />
                                    </Grid>
                                    <Separator Margin="0,5,0,10" />
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelThreshold}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="翻訳をトリガーする蓄積文字数" />
                                        </StackPanel>
                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="120"
                                            Height="32"
                                            ClearButtonEnabled="False"
                                            AcceptsExpression="False"
                                            SpinButtonPlacementMode="Inline"
                                            Maximum="500"
                                            Minimum="10"
                                            LargeChange="10"
                                            SmallChange="5"
                                            Value="{Binding AccumulateThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding IsAccumulateThresholdEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </StackPanel>
                            </ui:Card>
                        </StackPanel>

                        <!-- セクション: 表示・字幕 -->
                        <StackPanel x:Name="DisplaySection" Margin="0,0,0,30">
                            <ui:TextBlock
                                Margin="5,0,0,15"
                                FontSize="20"
                                FontWeight="Bold"
                                Text="表示・字幕設定" />

                            <!-- カード: 原文表示 -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelShowOriginal}" />
                                        <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="翻訳文の上にオリジナルの原文（英語など）を表示します。" />
                                    </StackPanel>
                                    <ui:ToggleSwitch
                                        Grid.Column="1"
                                        IsChecked="{Binding MainWindow.ShowOriginalCaption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        OffContent="{DynamicResource Off}"
                                        OnContent="{DynamicResource On}" />
                                </Grid>
                            </ui:Card>

                            <!-- カード: フォント設定（種類、サイズ、色、太字） -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <StackPanel>
                                    <!-- フォントの種類 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelCaptionFontFamily}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="字幕テキストのフォントファミリーを指定します。" />
                                        </StackPanel>
                                        <ComboBox
                                            Grid.Column="1"
                                            x:Name="CaptionFontFamilyBox"
                                            Width="180"
                                            Height="32"
                                            SelectionChanged="CaptionFontFamilyBox_SelectionChanged" />
                                    </Grid>
                                    <Separator Margin="0,5,0,10" />
                                    <!-- フォントサイズ -->
                                    <Grid Margin="0,5,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelCaptionFontSize}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="字幕テキストのフォントサイズを設定します。" />
                                        </StackPanel>
                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="120"
                                            Height="32"
                                            ClearButtonEnabled="False"
                                            AcceptsExpression="False"
                                            SpinButtonPlacementMode="Inline"
                                            Maximum="40"
                                            Minimum="10"
                                            Value="{Binding MainWindow.CaptionFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Separator Margin="0,5,0,10" />
                                    <!-- フォント色 -->
                                    <Grid Margin="0,5,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelCaptionFontColor}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="字幕テキストの色を設定します。" />
                                        </StackPanel>
                                        <ComboBox
                                            Grid.Column="1"
                                            x:Name="CaptionFontColorBox"
                                            Width="120"
                                            Height="32"
                                            SelectionChanged="CaptionFontColorBox_SelectionChanged" />
                                    </Grid>
                                    <Separator Margin="0,5,0,10" />
                                    <!-- 太字 -->
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelCaptionFontBold}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="字幕を太字で表示します。" />
                                        </StackPanel>
                                        <ui:ToggleSwitch
                                            Grid.Column="1"
                                            IsChecked="{Binding MainWindow.CaptionFontBold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            OffContent="{DynamicResource Off}"
                                            OnContent="{DynamicResource On}" />
                                    </Grid>
                                </StackPanel>
                            </ui:Card>

                            <!-- カード: 間隔設定 -->
                            <ui:Card Margin="0,0,0,10" Padding="15">
                                <StackPanel>
                                    <!-- 原文と翻訳の行間 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelLineSpacingOriginalTranslated}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="原文と翻訳文の行間（ピクセル単位）を設定します。" />
                                        </StackPanel>
                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="120"
                                            Height="32"
                                            ClearButtonEnabled="False"
                                            AcceptsExpression="False"
                                            SpinButtonPlacementMode="Inline"
                                            Maximum="30"
                                            Minimum="0"
                                            Value="{Binding MainWindow.LineSpacingOriginalTranslated, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Separator Margin="0,5,0,10" />
                                    <!-- 複数行の行間倍率 -->
                                    <Grid Margin="0,5,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelLineHeightMultiplier}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="テキストが複数行になった場合の行間倍率を設定します。" />
                                        </StackPanel>
                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="120"
                                            Height="32"
                                            ClearButtonEnabled="False"
                                            AcceptsExpression="False"
                                            SpinButtonPlacementMode="Inline"
                                            Maximum="2.5"
                                            Minimum="1.0"
                                            LargeChange="0.2"
                                            SmallChange="0.05"
                                            Value="{Binding MainWindow.LineHeightMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Separator Margin="0,5,0,10" />
                                    <!-- カードの間隔 -->
                                    <Grid Margin="0,5,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelItemSpacing}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="ホーム画面（字幕ログ）で表示されるカード間の隙間を指定します。" />
                                        </StackPanel>
                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="120"
                                            Height="32"
                                            ClearButtonEnabled="False"
                                            AcceptsExpression="False"
                                            SpinButtonPlacementMode="Inline"
                                            Maximum="40"
                                            Minimum="0"
                                            Value="{Binding MainWindow.ItemSpacing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Separator Margin="0,5,0,10" />
                                    <!-- 履歴の間隔 -->
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock FontWeight="SemiBold" Text="{DynamicResource LabelHistoryItemSpacing}" />
                                            <ui:TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Text="履歴画面で表示されるカード間の隙間を指定します。" />
                                        </StackPanel>
                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="120"
                                            Height="32"
                                            ClearButtonEnabled="False"
                                            AcceptsExpression="False"
                                            SpinButtonPlacementMode="Inline"
                                            Maximum="40"
                                            Minimum="0"
                                            Value="{Binding MainWindow.HistoryItemSpacing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </StackPanel>
                            </ui:Card>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
