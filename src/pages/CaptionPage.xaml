<Page
    x:Class="LiveCaptionsTranslator.CaptionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LiveCaptionsTranslator"
    xmlns:utils="clr-namespace:LiveCaptionsTranslator.Utils"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="CaptionPage"
    JournalEntry.KeepAlive="True"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <utils:ColorToBrushConverter x:Key="ColorToBrush" />
        <utils:BoolToFontWeightConverter x:Key="BoolToFontWeight" />
        <utils:FontFamilyConverter x:Key="FontFamilyConverter" />
        <Style x:Key="CaptionBlockStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <!--
        重要: ScrollViewerの中に Height="*" の行を含むGridを置くと、
        "*"行はScrollViewer内で高さ0になり、コンテンツがScrollViewerをオーバーフローしない。
        そのためすべてAuto高さのStackPanelで積み上げる構造にする。
    -->
    <ScrollViewer
        x:Name="CaptionPageScrollViewer"
        Margin="12,12,12,12"
        Background="Transparent"
        HorizontalScrollBarVisibility="Disabled"
        ScrollChanged="CaptionPageScrollViewer_ScrollChanged"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical">

            <!-- ログカードリスト（CaptionLogEnabled=trueの時のみ表示） -->
            <ui:Card
                x:Name="LogCards"
                Margin="0,0,0,0"
                Padding="8"
                Background="Transparent"
                BorderBrush="#00000000"
                Visibility="Collapsed">
                <ItemsControl
                    x:Name="LogCardItems"
                    MinHeight="50"
                    ItemsSource="{Binding DisplayLogCards, UpdateSourceTrigger=PropertyChanged}"
                    VirtualizingPanel.IsVirtualizing="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="12,10,12,10"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="6">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock
                                        x:Name="OriginalCaptionLog"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        FontSize="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontSizeLogOriginal}"
                                        FontWeight="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontBold, Converter={StaticResource BoolToFontWeight}}"
                                        FontFamily="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontFamily, Converter={StaticResource FontFamilyConverter}}"
                                        Foreground="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontColor, Converter={StaticResource ColorToBrush}, ConverterParameter={StaticResource TextFillColorSecondaryBrush}}"
                                        MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"
                                        Style="{StaticResource CaptionBlockStyle}"
                                        Text="{Binding SourceText}"
                                        ToolTip="{DynamicResource ToolTipClickToCopy}"
                                        Visibility="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.ShowOriginalCaption, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock
                                        x:Name="TranslatedCaptionLog"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        FontSize="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontSizeLog}"
                                        FontWeight="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontBold, Converter={StaticResource BoolToFontWeight}}"
                                        FontFamily="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontFamily, Converter={StaticResource FontFamilyConverter}}"
                                        Foreground="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontColor, Converter={StaticResource ColorToBrush}, ConverterParameter={StaticResource TextFillColorPrimaryBrush}}"
                                        MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"
                                        Text="{Binding TranslatedText}"
                                        ToolTip="{DynamicResource ToolTipClickToCopy}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionBlockStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.ShowOriginalCaption}" Value="True">
                                                        <Setter Property="Margin" Value="0,4,0,0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ui:Card>

            <!-- 原文カード（自動翻訳OFF時または ShowOriginalCaption=true時に表示） -->
            <ui:Card
                x:Name="OriginalCaptionCard"
                Margin="0,0,0,6"
                Padding="8"
                Background="Transparent"
                BorderThickness="0"
                Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        x:Name="OriginalCaption"
                        Background="Transparent"
                        Cursor="Hand"
                        FontSize="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontSizeOriginal}"
                        FontWeight="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontBold, Converter={StaticResource BoolToFontWeight}}"
                        FontFamily="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontFamily, Converter={StaticResource FontFamilyConverter}}"
                        Foreground="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontColor, Converter={StaticResource ColorToBrush}, ConverterParameter={StaticResource TextFillColorSecondaryBrush}}"
                        MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"
                        Style="{StaticResource CaptionBlockStyle}"
                        Text="{Binding DisplayOriginalCaption, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="{DynamicResource ToolTipClickToCopy}" />
                    <ui:Button
                        Grid.Column="1"
                        x:Name="ManualTranslateButton"
                        Margin="5,0,0,0"
                        Padding="6,4"
                        VerticalAlignment="Center"
                        Click="ManualTranslateButton_Click"
                        Icon="{ui:SymbolIcon Translate24}"
                        ToolTip="{DynamicResource ToolTipTranslateNow}" />
                </Grid>
            </ui:Card>

            <!-- 翻訳済みテキストカード（常に最下部） -->
            <ui:Card
                x:Name="TranslatedCaptionCard"
                MinHeight="43"
                Margin="0,0,0,8"
                Padding="8"
                Background="Transparent"
                BorderThickness="0">
                <TextBlock
                    x:Name="TranslatedCaption"
                    Background="Transparent"
                    Cursor="Hand"
                    FontSize="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontSize}"
                    FontWeight="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontBold, Converter={StaticResource BoolToFontWeight}}"
                    FontFamily="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontFamily, Converter={StaticResource FontFamilyConverter}}"
                    Foreground="{Binding Source={x:Static local:Translator.Setting}, Path=MainWindow.CaptionFontColor, Converter={StaticResource ColorToBrush}, ConverterParameter={StaticResource TextFillColorPrimaryBrush}}"
                    MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"
                    Style="{StaticResource CaptionBlockStyle}"
                    Text="{Binding DisplayTranslatedCaption, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="{DynamicResource ToolTipClickToCopy}" />
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
