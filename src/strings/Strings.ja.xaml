<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Common -->
    <sys:String x:Key="On">オン</sys:String>
    <sys:String x:Key="Off">オフ</sys:String>
    <sys:String x:Key="Yes">はい</sys:String>
    <sys:String x:Key="No">いいえ</sys:String>
    <sys:String x:Key="Open">開く</sys:String>
    <sys:String x:Key="New">新規作成</sys:String>
    <sys:String x:Key="Delete">削除</sys:String>
    <sys:String x:Key="Show">表示</sys:String>
    <sys:String x:Key="Hide">非表示</sys:String>
    <sys:String x:Key="Paused">[一時停止中]</sys:String>

    <!-- MainWindow -->
    <sys:String x:Key="MainWindowTitle">LiveCaptions Translator</sys:String>
    <sys:String x:Key="ToolTipPauseTranslation">翻訳を一時停止 (ログのみ)</sys:String>
    <sys:String x:Key="ToolTipOverlayWindow">オーバーレイウィンドウ</sys:String>
    <sys:String x:Key="ToolTipAlwaysOnTop">常に最前面</sys:String>
    <sys:String x:Key="ToolTipLogCards">字幕ログカード</sys:String>
    <sys:String x:Key="ToolTipShowOriginal">原文の表示/非表示</sys:String>
    <sys:String x:Key="ToolTipAutoScroll">自動スクロールのオン/オフ</sys:String>
    <sys:String x:Key="ToolTipClearTranslations">翻訳テキストをクリア (Ctrl+Shift+C)</sys:String>
    <sys:String x:Key="NavCaption">字幕</sys:String>
    <sys:String x:Key="NavSetting">設定</sys:String>

    
    <!-- Update Check -->
    <sys:String x:Key="UpdateTitle">新しいバージョンが利用可能です</sys:String>
    <sys:String x:Key="UpdateContent">新しいバージョンが検出されました: {0}&#x0A;現在のバージョン: {1}&#x0A;GitHub にアクセスして最新リリースをダウンロードしてください。</sys:String>
    <sys:String x:Key="ButtonUpdate">アップデート</sys:String>
    <sys:String x:Key="ButtonIgnoreVersion">このバージョンを無視する</sys:String>
    <sys:String x:Key="UpdateCheckFailed">[エラー] アップデート確認失敗</sys:String>
    <sys:String x:Key="OpenBrowserFailed">[エラー] ブラウザの起動に失敗しました</sys:String>

    <!-- CaptionPage -->
    <sys:String x:Key="ToolTipClickToCopy">クリックしてコピー</sys:String>
    <sys:String x:Key="ToolTipTranslateNow">今すぐ翻訳 (Ctrl+Shift+T)</sys:String>



    <!-- SettingPage -->
    <sys:String x:Key="LabelLiveCaptions">LiveCaptions</sys:String>
    <sys:String x:Key="LiveCaptionsInfo">Windows 11 バージョン 24H2 以降、音声入力言語（翻訳元言語）は Windows LiveCaptions 内でのみ変更可能です。&#x0A;&#x0A;注意: Windows LiveCaptions は直接閉じずに、「非表示」をクリックして非表示にしてください。</sys:String>
    <sys:String x:Key="ButtonShow">表示</sys:String>
    <sys:String x:Key="ButtonHide">非表示</sys:String>
    <sys:String x:Key="LabelAPIInterval">API 呼び出し間隔</sys:String>
    <sys:String x:Key="APIIntervalInfo">翻訳 API の呼び出し頻度を決定します。値が小さいほど、呼び出し頻度が高くなります。&#x0A;字幕が [API 呼び出し間隔] 回変化した後に一度、翻訳 API が呼び出されます。</sys:String>
    <sys:String x:Key="LabelTranslateAPI">翻訳 API</sys:String>
    <sys:String x:Key="TranslateAPIInfo">Google および Google2 以外のすべての API は、使用前に設定が必要です。</sys:String>
    <sys:String x:Key="LabelTargetLanguage">翻訳先言語</sys:String>
    <sys:String x:Key="TargetLanguageInfo">「使いたい翻訳先言語が一覧にない！」&#x0A;このコンボボックスの入力を直接編集して言語をカスタマイズできます。BCP 47 言語タグに従うことを推奨します。&#x0A;&#x0A;注意: 一部の API（DeepL など）は翻訳先言語の指定方法が異なる場合があります。詳細は公式ドキュメントを参照してください。&#x0A;組み込まれている言語についてはタグマッピングが内蔵されているため考慮不要ですが、希望の言語がリストにない場合はご注意ください。</sys:String>
    <sys:String x:Key="LabelAPISetting">API 設定</sys:String>
    <sys:String x:Key="ButtonOpen">開く</sys:String>
    <sys:String x:Key="LabelShowLatency">レイテンシ表示</sys:String>
    <sys:String x:Key="LabelShowOriginal">原文表示</sys:String>
    <sys:String x:Key="LabelContexts">コンテキスト数</sys:String>
    <sys:String x:Key="ContextsInfo">コンテキスト数:&#x0A;コンテキスト認識（Context Aware）が有効な場合に、コンテキストとして使用する文章の数を決定します。&#x0A;&#x0A;オーバーレイ表示数:&#x0A;字幕ログカードが有効な場合に表示するカードの数、およびオーバーレイウィンドウに表示する最大文章数を決定します。&#x0A;&#x0A;注意:&#x0A;コンテキスト数は表示文数以上である必要があります。満たさない場合、プログラムは自動的に調整します。</sys:String>
    <sys:String x:Key="LabelDisplaySentences">表示文数</sys:String>
    <sys:String x:Key="LabelContextAware">コンテキスト認識</sys:String>
    <sys:String x:Key="ContextAwareInfo">文脈（コンテキスト）に沿って翻訳します。&#x0A;翻訳精度は向上しますが、消費トークン数が増加します。</sys:String>
    <sys:String x:Key="LabelAutoTranslate">自動翻訳</sys:String>
    <sys:String x:Key="AutoTranslateInfo">字幕を自動的に翻訳します。&#x0A;オフにした場合、手動の翻訳ボタンをクリックしたときのみ翻訳されます。</sys:String>
    <sys:String x:Key="LabelAccumulateTrans">テキスト蓄積翻訳</sys:String>
    <sys:String x:Key="AccumulateTransInfo">翻訳前にテキストを蓄積します。&#x0A;蓄積された文字数がしきい値に達し、文末の区切りが検出されるまで翻訳を待機します。</sys:String>
    <sys:String x:Key="LabelThreshold">しきい値 (文字数)</sys:String>
    <sys:String x:Key="LabelUILanguage">UI 言語</sys:String>



    <!-- WelcomeWindow -->
    <sys:String x:Key="WelcomeTitle">はじめに</sys:String>
    <sys:String x:Key="WelcomeHeading">LiveCaptions Translator へようこそ！</sys:String>
    <sys:String x:Key="WelcomeDescription1">LiveCaptions Translator は Windows LiveCaptions に基づいています。&#x0A;初回実行前に、以下の手順に従って設定を行ってください。&#x0A;&#x0A;1. Windows LiveCaptions を開き、ガイドに従ってオンデバイス音声認識および言語パックに必要なファイルをダウンロードします。&#x0A;2. Windows LiveCaptions の ⚙️ 歯車アイコンをクリックして設定メニューを開き、[位置 &gt; 画面上にオーバーレイ表示] を選択します。&#x0A;3. LiveCaptions Translator の設定ページにある [非表示] ボタンをクリックして、Windows LiveCaptions を非表示にします。&#x0A;&#x0A;プログラムは自動的に設定ページに移動し、Windows LiveCaptions を開きました。設定完了後、メインページに戻ってリアルタイム音声翻訳をお楽しみいただけます。&#x0A;&#x0A;詳細については、Wiki をご覧ください: </sys:String>
    <sys:String x:Key="WelcomeDescription2">&#x0A;&#x0A;ヒント:&#x0A;入力言語を変更するには、設定ページで Windows LiveCaptions を [表示] させて、Windows LiveCaptions 側で変更を行ってください。</sys:String>
    <sys:String x:Key="WelcomeButtonText">設定を完了しました</sys:String>

    <!-- AppSettingWindow (Application Setting) -->
    <sys:String x:Key="AppSettingTitle">環境設定</sys:String>

    <!-- SettingWindow (API Setting) -->
    <sys:String x:Key="APISettingTitle">API 設定</sys:String>
    <sys:String x:Key="Prompt">プロンプト</sys:String>
    <sys:String x:Key="PromptNote1">プロンプト内の {0} は翻訳先言語を示します。プロンプトに {0} が含まれていることを確認してください。</sys:String>
    <sys:String x:Key="PromptNote2">翻訳元のテキストは 🔤 で囲まれています。</sys:String>
    <sys:String x:Key="CurrentConfigLabel">現在の設定: </sys:String>
    <sys:String x:Key="MinConfigWarning">少なくとも1つの設定を残す必要があります。</sys:String>
    <sys:String x:Key="ButtonLoadModels">モデルの読み込み</sys:String>
    <sys:String x:Key="OllamaApiUrlHelp">`api/chat` サフィックスを明示的に追加する必要はありません。</sys:String>
    <sys:String x:Key="LMStudioApiUrlHelp">`api/v1` で終わるベース URL。チャットエンドポイントとモデルは自動的に追加されます。</sys:String>
    <sys:String x:Key="OpenAIApiUrlHelp">ベース URL（通常は `v1` で終わるもの）の代わりに、フル URL（通常は `v1/chat/completions` で終わるもの）を使用します。</sys:String>
    
    <!-- Code-behind Messages -->
    <sys:String x:Key="MsgSetApiUrlFirst">先に API URL を設定してください。</sys:String>
    <sys:String x:Key="MsgModelsLoaded">{0} 個のモデルを読み込みました。</sys:String>
    <sys:String x:Key="MsgNoModelsFound">モデルが見つからないか、接続できません。サーバーが起動しているか確認してください。</sys:String>

    <!-- OverlayWindow ToolTips -->
    <sys:String x:Key="ToolTipOverlayTranslate">今すぐ翻訳</sys:String>
    <sys:String x:Key="ToolTipFontSizeIncrease">フォントサイズを大きくする</sys:String>
    <sys:String x:Key="ToolTipFontSizeDecrease">フォントサイズを小さくする</sys:String>
    <sys:String x:Key="ToolTipFontStrokeIncrease">フォント縁取りを太くする</sys:String>
    <sys:String x:Key="ToolTipFontStrokeDecrease">フォント縁取りを細くする</sys:String>
    <sys:String x:Key="ToolTipFontBold">フォントを太字にする</sys:String>
    <sys:String x:Key="ToolTipFontColor">フォント色</sys:String>
    <sys:String x:Key="ToolTipOpacityIncrease">背景の不透明度を上げる</sys:String>
    <sys:String x:Key="ToolTipOpacityDecrease">背景の不透明度を下げる</sys:String>
    <sys:String x:Key="ToolTipBackgroundColor">背景色</sys:String>
    <sys:String x:Key="ToolTipOnlyMode">字幕のみ、または翻訳のみを表示する</sys:String>
    <sys:String x:Key="ToolTipSwitchMode">字幕と翻訳の表示順を入れ替える</sys:String>
    <sys:String x:Key="ToolTipClickThrough">マウスクリック透過</sys:String>

    <!-- Home Screen Customization -->
    <sys:String x:Key="LabelCaptionFontSize">字幕フォントサイズ</sys:String>
    <sys:String x:Key="LabelCaptionFontBold">字幕を太字にする</sys:String>
    <sys:String x:Key="LabelCaptionFontColor">字幕フォント色</sys:String>
    <sys:String x:Key="LabelCaptionFontFamily">字幕フォントの種類</sys:String>
    <sys:String x:Key="LabelLineSpacingOriginalTranslated">翻訳前後の行間 (px)</sys:String>
    <sys:String x:Key="LabelLineHeightMultiplier">複数行の行間 (倍率)</sys:String>
    <sys:String x:Key="LabelItemSpacing">ホーム画面のカード間隔 (px)</sys:String>

    <sys:String x:Key="ToolTipLiveCaptions">Windows Live Captions の表示/非表示</sys:String>

    <!-- Colors -->
    <sys:String x:Key="ColorDefault">デフォルト</sys:String>
    <sys:String x:Key="ColorWhite">白</sys:String>
    <sys:String x:Key="ColorYellow">黄</sys:String>
    <sys:String x:Key="ColorLimeGreen">緑</sys:String>
    <sys:String x:Key="ColorAqua">水色</sys:String>
    <sys:String x:Key="ColorBlue">青</sys:String>
    <sys:String x:Key="ColorDeepPink">ピンク</sys:String>
    <sys:String x:Key="ColorRed">赤</sys:String>
    <sys:String x:Key="ColorBlack">黒</sys:String>
</ResourceDictionary>
