<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Common -->
    <sys:String x:Key="On">On</sys:String>
    <sys:String x:Key="Off">Off</sys:String>
    <sys:String x:Key="Yes">Yes</sys:String>
    <sys:String x:Key="No">No</sys:String>
    <sys:String x:Key="Open">Open</sys:String>
    <sys:String x:Key="New">New</sys:String>
    <sys:String x:Key="Delete">Delete</sys:String>
    <sys:String x:Key="Show">Show</sys:String>
    <sys:String x:Key="Hide">Hide</sys:String>
    <sys:String x:Key="Paused">[Paused]</sys:String>

    <!-- MainWindow -->
    <sys:String x:Key="MainWindowTitle">LiveCaptions Translator</sys:String>
    <sys:String x:Key="ToolTipPauseTranslation">Pause Translation (Log Only)</sys:String>
    <sys:String x:Key="ToolTipOverlayWindow">Overlay Window</sys:String>
    <sys:String x:Key="ToolTipAlwaysOnTop">Always on Top</sys:String>
    <sys:String x:Key="ToolTipLogCards">Log Cards of Captions</sys:String>
    <sys:String x:Key="ToolTipShowOriginal">Show/Hide Original Text</sys:String>
    <sys:String x:Key="ToolTipAutoScroll">Toggle Auto Scroll</sys:String>
    <sys:String x:Key="NavCaption">Caption</sys:String>
    <sys:String x:Key="NavSetting">Setting</sys:String>
    <sys:String x:Key="NavHistory">History</sys:String>
    <sys:String x:Key="NavInfo">Info</sys:String>
    
    <!-- Update Check -->
    <sys:String x:Key="UpdateTitle">New Version Available</sys:String>
    <sys:String x:Key="UpdateContent">A new version has been detected: {0}&#x0A;Current version: {1}&#x0A;Please visit GitHub to download the latest release.</sys:String>
    <sys:String x:Key="ButtonUpdate">Update</sys:String>
    <sys:String x:Key="ButtonIgnoreVersion">Ignore this version</sys:String>
    <sys:String x:Key="UpdateCheckFailed">[ERROR] Update Check Failed.</sys:String>
    <sys:String x:Key="OpenBrowserFailed">[ERROR] Open Browser Failed.</sys:String>

    <!-- CaptionPage -->
    <sys:String x:Key="ToolTipClickToCopy">Click To Copy</sys:String>
    <sys:String x:Key="ToolTipTranslateNow">Translate Now (Ctrl+Shift+T)</sys:String>

    <!-- HistoryPage -->
    <sys:String x:Key="ToolTipPreviousPage">Previous Page</sys:String>
    <sys:String x:Key="ToolTipNextPage">Next Page</sys:String>
    <sys:String x:Key="PlaceholderSearch">Search</sys:String>
    <sys:String x:Key="ToolTipExport">Export</sys:String>
    <sys:String x:Key="ToolTipDeleteAll">Delete All</sys:String>
    <sys:String x:Key="ToolTipRefresh">Refresh</sys:String>
    <sys:String x:Key="HeaderTime">Time</sys:String>
    <sys:String x:Key="HeaderCaption">Caption</sys:String>
    <sys:String x:Key="HeaderTranslated">Translated</sys:String>
    <sys:String x:Key="HeaderAPI">API</sys:String>
    <sys:String x:Key="DeleteHistoryTitle">Do you want to delete all history?</sys:String>
    <sys:String x:Key="DeleteHistoryContent">This operation cannot be undone!</sys:String>
    <sys:String x:Key="ExportSuccessTitle">Saved Success.</sys:String>
    <sys:String x:Key="ExportSuccessContent">File saved to: {0}</sys:String>
    <sys:String x:Key="ExportFailedTitle">Save Failed.</sys:String>
    <sys:String x:Key="ExportFailedContent">File save failed: {0}</sys:String>

    <!-- SettingPage -->
    <sys:String x:Key="LabelLiveCaptions">LiveCaptions</sys:String>
    <sys:String x:Key="LiveCaptionsInfo">After Windows 11 version 24H2, you can only change the Source Language in LiveCaptions.&#x0A;&#x0A;Note: Please click &quot;Hide&quot; to hide LiveCaptions instead of closing it directly.</sys:String>
    <sys:String x:Key="ButtonShow">Show</sys:String>
    <sys:String x:Key="ButtonHide">Hide</sys:String>
    <sys:String x:Key="LabelAPIInterval">API Interval</sys:String>
    <sys:String x:Key="APIIntervalInfo">Determines the frequency of translate API calls. The smaller it is, the more frequent API calls.&#x0A;The translate API is called once after the caption changes [API Interval] times.</sys:String>
    <sys:String x:Key="LabelTranslateAPI">Translate API</sys:String>
    <sys:String x:Key="TranslateAPIInfo">Except for Google and Google2, all other APIs require configuring before they can be used.</sys:String>
    <sys:String x:Key="LabelTargetLanguage">Target Language</sys:String>
    <sys:String x:Key="TargetLanguageInfo">&quot;There isn’t the target language I expect!&quot;&#x0A;You can directly edit the content of this combobox to customize the language, and it is recommended to follow the BCP 47 language tag.&#x0A;&#x0A;Note:&#x0A;Some of APIs (such as DeepL) needs another way to define target language, see their official docs for more details.&#x0A;No need to consider this for included target languages, since we've built in tag mappings. But if your expected language isn't in the list, keep this in mind.</sys:String>
    <sys:String x:Key="LabelAPISetting">API Setting</sys:String>
    <sys:String x:Key="ButtonOpen">Open</sys:String>
    <sys:String x:Key="LabelShowLatency">Show Latency</sys:String>
    <sys:String x:Key="LabelShowOriginal">Show Original</sys:String>
    <sys:String x:Key="LabelContexts">Contexts</sys:String>
    <sys:String x:Key="ContextsInfo">Contexts:&#x0A;Determines the number of context sentences when Context Aware is enabled.&#x0A;&#x0A;Overlay Sentences:&#x0A;Determines the number of displayed cards when Log Cards is enabled, as well as the max number of sentences displayed in the Overlay Window.&#x0A;&#x0A;Note:&#x0A;Contexts must be greater than or equal to Display Sentences. If not met, the program will automatically adjust them.</sys:String>
    <sys:String x:Key="LabelDisplaySentences">Display Sentences</sys:String>
    <sys:String x:Key="LabelContextAware">Context Aware</sys:String>
    <sys:String x:Key="ContextAwareInfo">Translate in context.&#x0A;It can improve translation accuracy, but will consume more tokens.</sys:String>
    <sys:String x:Key="LabelAutoTranslate">Auto Translate</sys:String>
    <sys:String x:Key="AutoTranslateInfo">Automatically translate captions.&#x0A;If turned off, translations only occur when clicking the manual Translate button.</sys:String>
    <sys:String x:Key="LabelAccumulateTrans">Accumulate Trans.</sys:String>
    <sys:String x:Key="AccumulateTransInfo">Accumulate text before translating.&#x0A;Wait to translate until the accumulated character count reaches the threshold, and a sentence boundary is detected.</sys:String>
    <sys:String x:Key="LabelThreshold">Threshold (Chars)</sys:String>
    <sys:String x:Key="LabelUILanguage">UI Language</sys:String>

    <!-- InfoPage -->
    <sys:String x:Key="InfoContribution">We welcome any form of contribution! You can provide suggestions or report bugs via GitHub issues, or contribute code directly by submitting Pull Requests.&#x0A;If this program is helpful to you, please consider giving us a star ✨!</sys:String>
    <sys:String x:Key="InfoRepository">Repository:</sys:String>
    <sys:String x:Key="InfoWiki">Wiki:</sys:String>
    <sys:String x:Key="InfoMaintainer">Maintainer:</sys:String>
    <sys:String x:Key="InfoAuthor">Author</sys:String>
    <sys:String x:Key="InfoVersion">Version:</sys:String>

    <!-- WelcomeWindow -->
    <sys:String x:Key="WelcomeTitle">Getting Started</sys:String>
    <sys:String x:Key="WelcomeHeading">Welcome to LiveCaptions Translator!</sys:String>
    <sys:String x:Key="WelcomeDescription1">LiveCaptions Translator is based on Windows LiveCaptions.&#x0A;Before your first running, you need to configure it according to the following steps:&#x0A;&#x0A;1. Open Windows LiveCaptions and follow the guide to download the necessary files for on-device speech recognition and language packs.&#x0A;2. Click the gear icon in Windows LiveCaptions to open the settings menu, and select &quot;Position &gt; Overlaid on screen&quot;.&#x0A;3. Click the &quot;Hide&quot; button located in the setting page of LiveCaptions Translator to hide Windows LiveCaptions.&#x0A;&#x0A;The program has automatically navigated to the setting page and opened Windows LiveCaptions. After completing the configuration, you can switch back to the main page and enjoy real-time audio translation.&#x0A;&#x0A;For more details, visit our wiki: </sys:String>
    <sys:String x:Key="WelcomeDescription2">&#x0A;&#x0A;Tip:&#x0A;To change the Source Language, please [Show] LiveCaptions on the setting page and do it in Windows LiveCaptions.</sys:String>
    <sys:String x:Key="WelcomeButtonText">I have fully understood and configured.</sys:String>

    <!-- SettingWindow (API Setting) -->
    <sys:String x:Key="APISettingTitle">API Setting</sys:String>
    <sys:String x:Key="Prompt">Prompt</sys:String>
    <sys:String x:Key="PromptNote1">The {0} in the prompt indicates the target language, so make sure your prompt includes {0}.</sys:String>
    <sys:String x:Key="PromptNote2">The source text is enclosed with 🔤.</sys:String>
    <sys:String x:Key="CurrentConfigLabel">Current Config: </sys:String>
    <sys:String x:Key="MinConfigWarning">You must keep at least one config.</sys:String>
    <sys:String x:Key="ButtonLoadModels">Load Models</sys:String>
    <sys:String x:Key="OllamaApiUrlHelp">No need to explicitly add `api/chat` suffix.</sys:String>
    <sys:String x:Key="LMStudioApiUrlHelp">Base URL ending with `api/v1`. Chat endpoint and models are appended automatically.</sys:String>
    <sys:String x:Key="OpenAIApiUrlHelp">Use Full Url (typically ending with `v1/chat/completions`) instead of Base Url (typically ending with just `v1`).</sys:String>

    <!-- Code-behind Messages -->
    <sys:String x:Key="MsgSetApiUrlFirst">Please set the API URL first.</sys:String>
    <sys:String x:Key="MsgModelsLoaded">Loaded {0} model(s).</sys:String>
    <sys:String x:Key="MsgNoModelsFound">No models found or unable to connect. Check that the server is running.</sys:String>

    <!-- OverlayWindow ToolTips -->
    <sys:String x:Key="ToolTipOverlayTranslate">Translate Now</sys:String>
    <sys:String x:Key="ToolTipFontSizeIncrease">Font Size Increase</sys:String>
    <sys:String x:Key="ToolTipFontSizeDecrease">Font Size Decrease</sys:String>
    <sys:String x:Key="ToolTipFontStrokeIncrease">Font Stroke Increase</sys:String>
    <sys:String x:Key="ToolTipFontStrokeDecrease">Font Stroke Decrease</sys:String>
    <sys:String x:Key="ToolTipFontBold">Font Bold</sys:String>
    <sys:String x:Key="ToolTipFontColor">Font Color</sys:String>
    <sys:String x:Key="ToolTipOpacityIncrease">Background Opacity Increase</sys:String>
    <sys:String x:Key="ToolTipOpacityDecrease">Background Opacity Decrease</sys:String>
    <sys:String x:Key="ToolTipBackgroundColor">Background Color</sys:String>
    <sys:String x:Key="ToolTipOnlyMode">Show only subtitles or translations</sys:String>
    <sys:String x:Key="ToolTipSwitchMode">Switch the order of subtitles and translations</sys:String>
    <sys:String x:Key="ToolTipClickThrough">Click Through</sys:String>

    <!-- Home Screen Customization -->
    <sys:String x:Key="LabelCaptionFontSize">Caption Font Size</sys:String>
    <sys:String x:Key="LabelCaptionFontBold">Caption Font Bold</sys:String>
    <sys:String x:Key="LabelCaptionFontColor">Caption Font Color</sys:String>
    <sys:String x:Key="LabelCaptionFontFamily">Caption Font Family</sys:String>
    <sys:String x:Key="LabelMainWindowOpacity">Home Window Opacity</sys:String>
    <sys:String x:Key="ToolTipLiveCaptions">Show/Hide Windows Live Captions</sys:String>

    <!-- Colors -->
    <sys:String x:Key="ColorDefault">Default</sys:String>
    <sys:String x:Key="ColorWhite">White</sys:String>
    <sys:String x:Key="ColorYellow">Yellow</sys:String>
    <sys:String x:Key="ColorLimeGreen">Green</sys:String>
    <sys:String x:Key="ColorAqua">Aqua</sys:String>
    <sys:String x:Key="ColorBlue">Blue</sys:String>
    <sys:String x:Key="ColorDeepPink">Pink</sys:String>
    <sys:String x:Key="ColorRed">Red</sys:String>
    <sys:String x:Key="ColorBlack">Black</sys:String>
</ResourceDictionary>
